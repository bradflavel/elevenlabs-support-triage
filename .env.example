# Copy this file to `.env` and fill in real values.
# Never commit `.env` itself - it's already in .gitignore.

# --- Database ---
# Local/dev: paste the DATABASE_URL from Railway `support-triage-db-dev` service
# (Variables tab). Prod URL is auto-wired by Railway at deploy time and should
# never be pasted locally.
DATABASE_URL=

# --- ElevenLabs ---
# From the agent's post-call webhook settings in the ElevenLabs dashboard.
# Same value used locally (for ngrok testing) and in prod.
ELEVENLABS_WEBHOOK_SECRET=

# From the agent overview page. Not required at runtime but logged for sanity.
ELEVENLABS_AGENT_ID=

# --- App ---
# `dev` locally, `prod` on Railway. Drives logging and env banner.
APP_ENV=dev
